{
  "name": "passit",
  "version": "0.0.1",
  "description": "A config-driven proxy gateway for Next.js App Router Route Handlers.",
  "license": "MIT",
  "author": "Pajar Rahmansyah <work@pajar.my.id> (https://github.com/pajarrahmansyah)",
  "homepage": "https://github.com/pajarrahmansyah/passit",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/pajarrahmansyah/passit.git"
  },
  "bugs": {
    "url": "https://github.com/pajarrahmansyah/passit/issues"
  },
  "type": "module",
  "main": "./dist/index.js",
  "module": "./dist/index.mjs",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "require": "./dist/index.js",
      "import": "./dist/index.mjs"
    },
    "./next": {
      "types": "./dist/next/plugin.d.ts",
      "require": "./dist/next/plugin.js",
      "import": "./dist/next/plugin.mjs"
    }
  },
  "scripts": {
    "build": "rimraf dist && tsup && tsc --emitDeclarationOnly --outDir dist && node scripts/rewire-dts-aliases.mjs",
    "dev": "tsup --watch",
    "typecheck": "tsc --noEmit",
    "typecheck:tests": "tsc -p tsconfig.test.json --noEmit",
    "test": "vitest tests/unit",
    "test:unit": "vitest run tests/unit",
    "test:live": "node scripts/run-live-tests.mjs"
  },
  "keywords": [
    "nextjs",
    "proxy",
    "gateway",
    "api",
    "passit"
  ],
  "peerDependencies": {
    "next": ">=14.0.0"
  },
  "peerDependenciesMeta": {
    "axios": {
      "optional": true
    }
  },
  "devDependencies": {
    "@types/node": "^25.6.0",
    "axios": "^1.15.2",
    "next": "^16.2.4",
    "rimraf": "^6.1.3",
    "tsup": "^8.5.1",
    "typescript": "^6.0.3",
    "vitest": "^4.1.5"
  }
}